#!/bin/bash
#SBATCH --job-name=metric_alignment
#SBATCH --partition=gpu_h100
#SBATCH --gres=gpu:1
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --time=01:00:00
#SBATCH --output=./conditional_spec_gaming/slurmfiles/slurm_output_%A_%a.out

# ==============================================================================
# Metric Alignment Ablation — Phase 2 (scoring only).
# Loads each judge model in turn, re-scores the pre-sampled completions using
# logprobs-based weighted average for reward, er_metric, and acc_metric.
#
# Run Phase 1 (sampling, CPU-only) locally first:
#   python -m llm_agent.ablations.metric_alignment.run_metric_alignment_ablation \
#       --phase sample
#
# Then submit this job for Phase 2:
#   sbatch llm_agent/jobs/run_metric_alignment_ablation.job
#
# To override the judge model(s):
#   JUDGE_MODELS="meta-llama/Llama-3.1-8B-Instruct" \
#     sbatch llm_agent/jobs/run_metric_alignment_ablation.job
#
# To override the number of samples (re-runs sampling before scoring):
#   N_SAMPLES=200 sbatch llm_agent/jobs/run_metric_alignment_ablation.job
# ==============================================================================

module purge
module load 2024
module load Python/3.12.3-GCCcore-13.3.0
module load CUDA/12.6.0

cd $HOME/conditional_spec_gaming/
source ./trl_env6/bin/activate

N_SAMPLES=${N_SAMPLES:-10}

# Build optional --judge_models argument
if [ -n "${JUDGE_MODELS}" ]; then
    JUDGE_ARGS="--judge_models ${JUDGE_MODELS}"
else
    JUDGE_ARGS=""
fi

python -m llm_agent.ablations.metric_alignment.run_metric_alignment_ablation \
    --phase all \
    --num_samples ${N_SAMPLES} \
    ${JUDGE_ARGS}

echo "Job complete!"
