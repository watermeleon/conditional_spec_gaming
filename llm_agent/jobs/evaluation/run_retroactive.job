#!/bin/bash
#SBATCH --job-name=retroactive_eval
#SBATCH --partition=rome
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --time=01:59:00
#SBATCH --output=./slurmfiles/slurm_output_%A_%a.out

module purge
module load 2024
module load Python/3.12.3-GCCcore-13.3.0
module load CUDA/12.6.0

cd $HOME/conditional_spec_gaming/
source ./trl_env6/bin/activate

MODEL_NAME="gemma_1_1_2b_it"
EXP_NAME="llm_agent_grpo"
ENV_NAME="therapy_talk"

export OPENAI_API_KEY='your-api-key-here'

srun python -m llm_agent.retroactive.retroactive_eval \
    --completions_dir results/$ENV_NAME/$MODEL_NAME/$EXP_NAME \
    --environment $ENV_NAME \
    --eval_n_steps 25
